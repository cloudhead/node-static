{
  "name": "node-static",
  "version": "0.7.11",
  "description": "simple, compliant file streaming module for node",
  "author": "Alexis Sellier <alexis@cloudhead.io>",
  "contributors": [
    "Pablo Cantero <pablo@pablocantero.com>",
    "Ionică Bizău <bizauionica@gmail.com>",
    "Brett Zamir"
  ],
  "type": "module",
  "main": "./lib/node-static",
  "exports": {
    ".": {
      "import": "./lib/node-static.js",
      "require": "./dist/node-static.cjs"
    }
  },
  "license": "MIT",
  "bin": {
    "static": "bin/cli.js"
  },
  "keywords": [
    "http",
    "static",
    "file",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "http://github.com/cloudhead/node-static"
  },
  "scripts": {
    "start": "./bin/cli.js",
    "lint": "eslint .",
    "mocha": "vows --spec --isolate",
    "test": "c8 npm run mocha"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "mime": "^2.5.2",
    "minimatch": "^3.0.4"
  },
  "devDependencies": {
    "c8": "^7.7.3",
    "command-line-basics": "^1.0.1",
    "eslint": "^7.30.0",
    "got": "^9.6.0",
    "vows": "latest"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "bugs": {
    "url": "https://github.com/cloudhead/node-static/issues"
  },
  "homepage": "https://github.com/cloudhead/node-static",
  "directories": {
    "example": "examples",
    "test": "test"
  }
}
